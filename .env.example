# ============================================================
# .env.example — Plantilla de variables de entorno
# Copia este archivo a .env (local) o configura las variables
# en el dashboard de Vercel (producción).
# ============================================================

# ============================================================
# 🌐 URLs (ajustar según el dominio de Vercel y Render)
# ============================================================
# ⚠️  VITE_API_URL debe ser la URL del BACKEND NestJS (Render),
# NO la del frontend de Vercel. Ejemplos:
#   - Local:       http://localhost:3000
#   - Producción:  https://sportmatch-api.onrender.com
#   - Otro host:   https://<tu-backend>.onrender.com
# El frontend lo usa para llamar a /api/v1/ai/chat y otros endpoints.
VITE_API_URL=https://sportmatch-api.onrender.com

# Dominio público del FRONTEND (Vercel). Render lo usa para configurar CORS.
FRONTEND_URL=https://sportmatch-connect-juan-alonso.vercel.app

# ============================================================
# 🗄️ Supabase (credenciales del proyecto)
# ============================================================
VITE_SUPABASE_URL=https://gzyoxfhzuxknqacplapi.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_RWQAc4K1J0zI3RZKRDXHYw_QRIF30D9
SUPABASE_JWT_SECRET=tu_supabase_jwt_secret_aqui

# ============================================================
# 🗄️ Database (Supabase Postgres directo)
# ============================================================
DATABASE_URL=postgresql://postgres.gzyoxfhzuxknqacplapi:TU_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.gzyoxfhzuxknqacplapi:TU_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ============================================================
# 🔐 Auth propio (opcional)
# ============================================================
JWT_SECRET=una_clave_aleatoria_segura_de_al_menos_32_caracteres

# ============================================================
# 🧠 Vertex AI (Google Gen AI) — CRÍTICO PARA PRODUCCIÓN
# ============================================================
# IMPORTANTE en Vercel: NO uses GOOGLE_APPLICATION_CREDENTIALS (apunta a un archivo).
# En su lugar, pega el CONTENIDO COMPLETO del JSON del Service Account aquí:
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"sportmach-core","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}'

# Configuración del modelo
GOOGLE_CLOUD_PROJECT=sportmach-core
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_ID=gemini-2.5-flash
VERTEX_AI_MAX_TOKENS=1024
VERTEX_AI_TEMPERATURE=0.7
VERTEX_AI_MAX_RETRIES=3
VERTEX_AI_TIMEOUT_MS=30000
VERTEX_AI_RATE_LIMIT_PER_MINUTE=20

# ============================================================
# 🔌 Server (puerto, modo de ejecución)
# ============================================================
PORT=3000
NODE_ENV=production
