# ============================================================
# SPORTMATCH CONNECT — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# ============================================================

# ── SUPABASE (Backend Principal) ─────────────────────────────
VITE_USE_MOCKS=false
VITE_SUPABASE_URL=https://gzyoxfhzuxknqacplapi.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── MODO HYBRID ───────────────────────────────────────────────
# VITE_USE_MOCKS=true

# ── STRIPE (Pasarela de pago) ────────────────────────────────
# SOLO CLAVE PÚBLICA (frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# NUNCA subas esta al frontend ni a GitHub
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ── MAPBOX (Mapa en tiempo real) ─────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiYOUR_USER","a":"YOUR_TOKEN"

# ── VERCEL POSTGRES (Legado — reemplazado por Supabase) ───────
# POSTGRES_URL=postgresql://...