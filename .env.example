# ============================================================
# SPORTMATCH CONNECT — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# ============================================================

# ── SUPABASE (Backend Principal) ─────────────────────────────
# Obtén estos valores en: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# ── MODO HYBRID ───────────────────────────────────────────────
# Si se omiten las vars de Supabase, el sistema usa mocks automáticamente.
# Para forzar mocks incluso con Supabase configurado:
# VITE_USE_MOCKS=true

# ── MAPBOX (Mapa en tiempo real) ─────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiVFVfVVNFUiIsImEiOiJUVV9UT0tFTiJ9.xxxxxxxxx

# ── VERCEL POSTGRES (Legado — reemplazado por Supabase) ───────
# Solo necesario si aún usas el adaptador @vercel/postgres
# POSTGRES_URL=postgresql://...
