{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": [
    "src/shared/i18n/index.ts",
    "src/styles.css",
    "**/*.css"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev:frontend": "vite --port 5173 --strictPort",
    "dev:backend:install": "cd server && npm install --silent",
    "dev:backend": "cd server && npm run dev",
    "dev": "node scripts/dev-stack.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "sonar:up": "docker compose -f docker-compose.sonar.yml up -d",
    "sonar:down": "docker compose -f docker-compose.sonar.yml down",
    "sonar:scan": "npx sonarqube-scanner",
    "prepare": "husky",
    "start": "cd server && npm install && npm run build && npm run start:prod"
  },
